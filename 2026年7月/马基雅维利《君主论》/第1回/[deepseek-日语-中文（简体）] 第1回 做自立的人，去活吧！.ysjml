                <spell/>
            </t>
            <t index="114" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:13,425</start-time>
                <end-time>00:06:14,780</end-time>
                <translation>传统观念就是如此</translation>
                <original>従来はそうだったんですね</original>
                <spell/>
            </t>
            <t index="115" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:14,780</start-time>
                <end-time>00:06:16,350</end-time>
                <translation>因为那是文艺复兴的时代</translation>
                <original>ベネスタンスの時代だったから</original>
                <spell/>
            </t>
            <t index="116" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:16,350</start-time>
                <end-time>00:06:17,280</end-time>
