            </t>
            <t index="380" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:18:58,678</start-time>
                <end-time>00:19:01,792</end-time>
                <translation>人一旦成功了一次</translation>
                <original>絶対してその人というのは一度成功してしまうと</original>
