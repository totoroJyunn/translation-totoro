            <t index="378" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:18:51,698</start-time>
                <end-time>00:18:54,276</end-time>
                <translation>所以 他阅读那些事例 </translation>
                <original>ですからその事例を読んで</original>
                <spell/>
            </t>
            <t index="379" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:18:54,276</start-time>
                <end-time>00:18:58,678</end-time>
                <translation>要主动去改变</translation>
                <original>自ら変えていこうということを彼は言いたかったわけなんです</original>
