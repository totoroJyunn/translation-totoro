                <original>でこれが出てきた</original>
                <spell/>
            </t>
            <t index="117" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:17,280</start-time>
                <end-time>00:06:18,000</end-time>
                <translation>没错</translation>
                <original>そうなんです</original>
                <spell/>
            </t>
            <t index="118" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:18,000</start-time>
                <end-time>00:06:18,900</end-time>
                <translation>于是人们发现</translation>
                <original>それで発見</original>
                <spell/>
            </t>
            <t index="119" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:18,900</start-time>
                <end-time>00:06:20,060</end-time>
                <translation>这是一本离经叛道的书</translation>
                <original>これはとんでもない本だと</original>
                <spell/>
            </t>
            <t index="120" hasRuby="0" id="" time="" vertical="0" torder="1">
                <start-time>00:06:20,060</start-time>
                <end-time>00:06:21,632</end-time>
                <translation>总的来说 可以这么理解</translation>
                <original>どちらかといえばそういうことになりますね</original>
                <spell/>
            </t>
            <t index="121" hasRuby="0" id="" time="" vertical="0" torder="1">
