            </t>
            <t id="" hasRuby="0" time="" torder="1" index="468" vertical="0">
                <start-time>00:22:48,200</start-time>
                <end-time>00:22:49,292</end-time>
                <translation>我是这么认为的</translation>
                <original>というふうに思います</original>
                <spell/>
            </t>
            <t id="" hasRuby="0" time="" torder="1" index="469" vertical="0">
                <start-time>00:22:49,292</start-time>
                <end-time>00:22:51,586</end-time>
                <translation>对于生活在阶级社会中的读者们</translation>
                <original>階級社会で生きている読者たちに</original>
