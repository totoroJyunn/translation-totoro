                <original>でそれを｢教養小説｣</original>
                <spell/>
            </t>
            <t id="" hasRuby="0" time="" torder="1" index="40" vertical="0">
                <start-time>00:02:11,560</start-time>
                <end-time>00:02:13,750</end-time>
                <translation>或“Bildungsroman”</translation>
                <original>｢ビルドゥングスロマン｣と呼びますね</original>
