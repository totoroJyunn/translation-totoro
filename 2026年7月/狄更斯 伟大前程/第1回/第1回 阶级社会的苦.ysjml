                <original/>
                <spell/>
            </t>
            <t id="" hasRuby="0" time="" torder="1" index="471" vertical="0">
                <start-time>00:22:54,944</start-time>
                <end-time>00:22:57,309</end-time>
                <translation>不过 我们现在所生活的社会</translation>
