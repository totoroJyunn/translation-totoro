            </t>
            <t id="" hasRuby="0" time="" torder="1" index="454" vertical="0">
                <start-time>00:22:12,860</start-time>
                <end-time>00:22:14,849</end-time>
                <translation>所以会让人想知道“后来会怎样呢”</translation>
                <original>どうなるのっていう</original>
