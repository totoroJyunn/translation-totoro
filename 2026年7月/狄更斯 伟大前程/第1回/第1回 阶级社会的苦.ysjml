                <start-time>00:02:28,948</start-time>
                <end-time>00:02:31,718</end-time>
                <translation>或是成长小说之类的</translation>
                <original>成長の小説みたいなものだと</original>
                <spell/>
            </t>
            <t id="" hasRuby="0" time="" torder="1" index="48" vertical="0">
                <marks>
                    <mark top="">默认标记</mark>
                </marks>
                <start-time>00:02:31,718</start-time>
                <end-time>00:02:33,075</end-time>
                <translation>可以这么理解</translation>
                <original>になると思います</original>
                <spell/>
            </t>
            <t id="" hasRuby="0" time="" torder="1" index="49" vertical="0">
                <start-time>00:02:33,075</start-time>
                <end-time>00:02:34,554</end-time>
                <translation>说到成长</translation>
                <original>成長と言われると</original>
                <spell/>
            </t>
