                <start-time>00:00:22,100</start-time>
                <end-time>00:00:25,075</end-time>
                <translation>ch17: 我非常仰慕她</translation>
                <original>I admire her dreadfully,</original>
                <spell/>
            </t>
            <t id="" hasRuby="0" time="" torder="1" index="8" vertical="0">
                <marks>
